{
  "name": "job-board-aggregator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Finance/business internship aggregator + notifier. ATS-API scraper core lifted from career-ops (MIT).",
  "engines": { "node": ">=22" },
  "scripts": {
    "test": "node --test",
    "scan": "node --env-file-if-exists=.env scan.mjs",
    "scan:json": "node --env-file-if-exists=.env scan.mjs --json",
    "scan:notify": "node --env-file-if-exists=.env scan.mjs --notify",
    "verify": "node verify-slugs.mjs",
    "schedule:install": "sh scripts/install-cron.sh"
  }
}
