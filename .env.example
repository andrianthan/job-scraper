# job-board-aggregator — notification channel config
# Copy this file to .env and fill in the values you want to use.
# At least one channel (Discord or email) must be configured for --notify to send.
# If neither is set, new jobs print to stdout instead (useful for dry runs).

# Discord: paste your webhook URL from Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=

# Email via Resend (https://resend.com — free tier: 100 emails/day)
# NOTIFY_EMAIL = recipient address
# RESEND_API_KEY = API key from the Resend dashboard
# NOTIFY_EMAIL_FROM = sender address (default: onboarding@resend.dev if omitted)
NOTIFY_EMAIL=
RESEND_API_KEY=
NOTIFY_EMAIL_FROM=

# Field sub-channel webhooks (optional) — auto-route jobs by title into field
# channels and ping the matching role. Create one webhook per channel in Discord
# (Channel → Edit → Integrations → Webhooks) and paste the URLs here.
FIELD_WEBHOOK_FINANCE=
FIELD_WEBHOOK_CONSULTING=
FIELD_WEBHOOK_MARKETING_SALES=
FIELD_WEBHOOK_TECH_DATA=
FIELD_WEBHOOK_OPS_HR=

# Fellowships field channel webhook (optional)
FIELD_WEBHOOK_FELLOWSHIPS=

# LLM classifier via OpenRouter (optional) — relevance gate + field tagging.
# Without it, classification falls back to keyword matching in field-router.mjs.
# OPENROUTER_JOB_SCRAPER = your OpenRouter API key
# CLASSIFIER_MODEL = OpenRouter model id (default anthropic/claude-haiku-4.5)
OPENROUTER_JOB_SCRAPER=
CLASSIFIER_MODEL=

# Firecrawl (optional) — scrape career sites without a public ATS API.
FIRECRAWL_API_KEY=

# Freshness: only notify postings newer than this many days (default 21, 0=off).
# Filters out old roles employers repost to regain traction.
MAX_JOB_AGE_DAYS=
